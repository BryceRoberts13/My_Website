---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import ProjectsWithModal from '../components/ProjectsWithModal';
import Contact from '../components/Contact.astro';
import { projects } from '../data/projects';
---
<Layout title="My Website">
  <main>
    <Hero name="Your Name" tagline="Developer & Creator" />
    <About
      bio="Your bio goes here. Tell visitors about yourself, your background, and what you do."
      skills={['JavaScript', 'TypeScript', 'Astro', 'React']}
    />
    <section id="projects">
      <h2>Projects</h2>
      <ProjectsWithModal client:load projects={projects} />
    </section>
    <Contact
      links={[
        { label: 'GitHub', url: 'https://github.com/yourusername' },
        { label: 'LinkedIn', url: 'https://linkedin.com/in/yourusername' },
        { label: 'Email', url: 'mailto:your@email.com' },
      ]}
    />
  </main>
</Layout>
